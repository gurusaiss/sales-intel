PORT=4000

# Optional: if set, AI summaries/outreach drafts use real Groq (Llama 3.3 70B)
# generations. Free, no credit card. Get a key at console.groq.com/keys.
# If unset, the backend falls back to a deterministic template.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: if set AND a company domain is provided in a search, real Hunter.io
# data is used instead of the mock provider. Get a free key at hunter.io/api-keys
# (25 searches/month free, no credit card). NOTE: Hunter blocks Gmail/Yahoo/etc.
# signups — needs a professional email domain, or "Continue with Google" OAuth.
HUNTER_API_KEY=

# Alternative to Hunter if you don't have a professional email — Snov.io accepts
# Gmail signup. Free tier: 50 credits/month, no card. Get keys at app.snov.io
# under Settings > API. Used only if HUNTER_API_KEY is unset and a domain is given.
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# Optional: enables real Gmail send-as-you (queue view "Send via Gmail" button).
# Free, no card. Set up at console.cloud.google.com: enable Gmail API, create
# an OAuth consent screen (External, add yourself as a test user), scope
# gmail.send, then create an OAuth Client ID (Web application) with
# GOOGLE_REDIRECT_URI below as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Strongly recommended once deployed publicly (e.g. on Render): a shared
# secret required (as an x-api-key header) on every /api/search, /api/persons,
# /api/draft, /api/queue, /api/send-email, and /auth/google/disconnect call.
# Without this, anyone who finds your deployed URL can call those endpoints —
# including sending real email once Gmail is connected. Leave blank for local
# dev (no auth enforced). Generate any random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Must match VITE_APP_API_KEY (frontend) and API_KEY in extension/config.js.
APP_API_KEY=

# STRONGLY RECOMMENDED once deployed: Render's free web service disk is
# EPHEMERAL — backend/data/*.json gets wiped on every redeploy and on
# spin-down/spin-up after idling. Without this, real captured data is at
# risk on every future `git push`. Fix: a free Redis-compatible KV store.
# Free, no card: upstash.com -> create a Redis database -> REST API tab ->
# copy the URL and token below. If left blank, falls back to local JSON
# files (fine for local dev, NOT fine once deployed).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
