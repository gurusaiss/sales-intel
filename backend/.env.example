PORT=4000

# Optional: if set, AI summaries/outreach drafts use real Claude generations.
# If unset, the backend falls back to a deterministic template (safe for local dev).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: if set AND a company domain is provided in a search, real Hunter.io
# data is used instead of the mock provider. Get a free key at hunter.io/api-keys
# (25 searches/month free, no credit card).
HUNTER_API_KEY=
