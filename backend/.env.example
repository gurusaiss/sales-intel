PORT=4000

# Optional: if set, AI summaries/outreach drafts use real Groq (Llama 3.3 70B)
# generations. Free, no credit card. Get a key at console.groq.com/keys.
# If unset, the backend falls back to a deterministic template.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: if set AND a company domain is provided in a search, real Hunter.io
# data is used instead of the mock provider. Get a free key at hunter.io/api-keys
# (25 searches/month free, no credit card).
HUNTER_API_KEY=
